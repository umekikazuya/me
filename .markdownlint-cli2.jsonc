{
	"config": {
		// 見出しの階層順を強制（h1 -> h3 のような飛びを禁止）
		"MD001": true,
		// 順序なしリストの記号を統一（ハイフン "-" 推奨）
		"MD004": {
			"style": "dash"
		},
		"MD013": {
			"line_length": 80,
			"code_blocks": false,
			"tables": false
		},
		// 見出しの直後に空行を入れる（レンダリング崩れ防止）
		"MD022": true,
		// ファイル末尾の空行を1つに強制
		"MD047": true,
		// インラインHTMLを許可（<img>タグで画像サイズ調整したい時などに便利）
		"MD033": false
	}
}